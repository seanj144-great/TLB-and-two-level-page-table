#include "Clock.h"

Clock::Clock(int frameCount) : frameCount(frameCount), clockHand(0) {
    frames.resize(frameCount, {-1, -1, false});
}

int Clock::evictAndReplace(int pid, int pageNumber, int& evictedPage) {
    while (true) {
        FrameEntry& current = frames[clockHand];

        if (current.pid == -1 || !current.referenced) {
            evictedPage = current.pageNumber;
            current = {pid, pageNumber, true};
            int victimFrame = clockHand;
            clockHand = (clockHand + 1) % frameCount;
            return victimFrame;
        }

        current.referenced = false;
        clockHand = (clockHand + 1) % frameCount;
    }
}